---
import { USER_JOB } from "@/data/constant"
import Layout from "@/layouts/Layout.astro"
import { ChevronRight } from "@lucide/astro"
import { getCollection } from "astro:content"

const projects = await getCollection("projects")
const featured = projects
  .sort((a, b) => Date.parse(b.data.createdAt) - Date.parse(a.data.createdAt))
  .slice(0, 4)
---

<Layout
  meta={{
    description:
      "Full Stack & Mobile Flutter Developer based in Jember, East Java, Indonesia. Interested in building digital experiences that are fast, elegant, and meaningful.",
    keywords: "Full Stack Developer, Mobile Flutter Developer, Portfolio",
  }}
>
  <!-- Hero Section -->
  <section class="mx-auto max-w-4xl px-6 py-24 md:py-32">
    <div class="space-y-6">
      <div class="flex items-center gap-3">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-primary"
        >
          <span class="size-1.5 animate-pulse rounded-full bg-primary"></span>
          Available for work
        </span>
      </div>

      <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-6xl">
        Hi, I'm{" "}
        <span
          class="bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent"
        >
          Muhammad <br />Izza Alfiansyah
        </span>
      </h1>

      <p class="max-w-xl text-lg text-foreground/60 md:text-xl">
        a {USER_JOB} that building digital experiences that are fast, elegant, and
        meaningful.
      </p>

      <div class="flex flex-wrap items-center gap-3 pt-2">
        <a
          href="/project"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-black transition-opacity hover:opacity-90"
        >
          View Projects
          <ChevronRight size={16} />
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-lg border px-5 py-2.5 text-sm font-semibold transition-colors hover:border-primary/50 hover:text-primary"
        >
          Contact Me
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Projects -->
  <section class="mx-auto max-w-4xl px-6 pb-24">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-bold tracking-tight">Featured Projects</h2>
        <p class="mt-1 text-sm text-foreground/50">
          A selection of my recent work
        </p>
      </div>
      <a href="/project" class="text-sm text-primary hover:underline">
        View all →
      </a>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        featured.map((project) => (
          <a
            href={`/project/${project.data.title.toLowerCase().replace(/\s+/g, "-")}`}
            class="group overflow-hidden rounded-xl border bg-background transition-all hover:border-primary/50 hover:shadow-lg hover:shadow-primary/5"
          >
            <div class="aspect-video w-full overflow-hidden bg-foreground/5">
              {project.data.images && project.data.images.length > 0 && (
                <img
                  src={project.data.images[0]}
                  alt={project.data.title}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              )}
            </div>
            <div class="p-4">
              <h3 class="font-semibold">{project.data.title}</h3>
              <p class="mt-1 line-clamp-2 text-sm text-foreground/60">
                {project.body}
              </p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {project.data.tags.slice(0, 3).map((tag) => (
                  <span class="rounded-full bg-foreground/5 px-2 py-0.5 text-xs text-foreground/60">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
