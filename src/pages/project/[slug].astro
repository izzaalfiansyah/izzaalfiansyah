---
import Layout from "@/layouts/Layout.astro"
import { projects } from "@/data/projects"

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }))
}

const { project } = Astro.props
---

<Layout
  title={project.title}
  meta={{
    description: project.description,
  }}
>
  <div class="mx-auto max-w-4xl px-6 py-16">
    <!-- Back button -->
    <a
      href="/project"
      class="mb-8 inline-flex items-center gap-2 text-sm text-foreground/50 transition-colors hover:text-foreground"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m15 18-6-6 6-6"></path>
      </svg>
      Back to Projects
    </a>

    <!-- Project Image -->
    <div class="mb-8 overflow-hidden rounded-2xl border bg-foreground/5">
      <img
        src={project.image}
        alt={project.title}
        class="h-auto w-full object-cover"
      />
    </div>

    <!-- Project Info -->
    <div class="space-y-4">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
          {project.title}
        </h1>

        <div class="flex gap-2">
          {
            project.links?.github && (
              <a
                href={project.links.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-medium transition-colors hover:border-foreground/30"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                >
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                </svg>
                GitHub
              </a>
            )
          }
          {
            project.links?.live && (
              <a
                href={project.links.live}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-black transition-opacity hover:opacity-90"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" x2="21" y1="14" y2="3" />
                </svg>
                Live Demo
              </a>
            )
          }
        </div>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2">
        {
          project.tags.map((tag) => (
            <span class="rounded-full border border-primary/30 bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {tag}
            </span>
          ))
        }
      </div>

      <!-- Description -->
      <div class="prose prose-sm dark:prose-invert max-w-none">
        <p class="text-foreground/70 leading-relaxed">
          {project.description}
        </p>
      </div>
    </div>
  </div>
</Layout>
