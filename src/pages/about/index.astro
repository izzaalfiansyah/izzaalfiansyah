---
import Layout from "@/layouts/Layout.astro"
import { techstack } from "@/data/techstack"
import InterestedWithMe from "@/components/InterestedWithMe.astro"
import AboutImage from "@/assets/images/about.png"
import { Image } from "astro:assets"

const inverteds = ["rust", "next", "socket", "express", "github"]

const categories = ["all", ...Array.from(new Set(techstack.map((t) => t.category)))] as const
---

<Layout
  title="About Me"
  meta={{
    description:
      "My Name is Muhammad Izza Alfiansyah. I'm a Full Stack & Mobile Flutter Developer based in Jember, East Java, Indonesia.",
  }}
>
  <div class="mx-auto max-w-4xl px-6 py-16">
    <!-- Profile Section -->
    <div class="mb-16 flex flex-col gap-8 md:flex-row md:gap-12">
      <div class="shrink-0">
        <div
          class="size-36 overflow-hidden rounded-2xl border-2 border-primary/20 md:size-48"
        >
          <Image
            src={AboutImage}
            alt="Muhammad Izza Alfiansyah"
            class="h-full w-full object-cover"
          />
        </div>
      </div>

      <div class="space-y-4">
        <div>
          <p
            class="text-sm font-medium text-primary uppercase tracking-widest mb-2"
          >
            About Me
          </p>
          <h1 class="text-3xl font-bold tracking-tight md:text-4xl">
            Muhammad Izza Alfiansyah
          </h1>
          <p class="mt-1 text-foreground/60">
            Full Stack &amp; Mobile Flutter Developer
          </p>
        </div>

        <div class="space-y-3 text-foreground/70 leading-relaxed">
          <p>
            Hello! My Name is Muhammad Izza Alfiansyah and you can call me
            <strong class="text-foreground">Alfian</strong>. I am a Full Stack
            &amp; Mobile Flutter Developer at{" "}
            <strong class="text-foreground">ERA Indonesia</strong>. I Live in
            Jember Regency, East Java Indonesia.
          </p>
          <p>
            I started programming when I was in high school at{" "}
            <strong class="text-foreground">SMK PGRI 5 Jember</strong>, The most
            meritorious place in my ability development. I am very enthusiastic
            about learning new things in the world of technology.
          </p>
        </div>

        <div class="flex flex-wrap gap-2 pt-2">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-black transition-opacity hover:opacity-90"
          >
            Contact Me
          </a>
          <a
            href="/project"
            class="inline-flex items-center gap-2 rounded-lg border px-4 py-2 text-sm font-semibold transition-colors hover:border-primary/50 hover:text-primary"
          >
            View Projects
          </a>
        </div>
      </div>
    </div>

    <!-- Tech Stack Section -->
    <div>
      <h2 class="mb-2 text-2xl font-bold tracking-tight">Tech Stack</h2>
      <p class="mb-8 text-foreground/50 text-sm">
        Technologies I work with on a daily basis
      </p>

      <!-- Filter Buttons -->
      <div class="mb-6 flex flex-wrap gap-2" id="filter-buttons">
        {categories.map((cat) => (
          <button
            data-category={cat}
            class={`filter-btn capitalize rounded-lg border px-3 py-1.5 text-xs font-medium transition-all ${
              cat === "all"
                ? "border-primary bg-primary text-black"
                : "border-border text-foreground/60 hover:border-primary/50 hover:text-foreground"
            }`}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Tech Stack Grid -->
      <div
        class="grid grid-cols-3 gap-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6"
        id="techstack-grid"
      >
        {
          techstack.map((tech) => (
            <div
              class="tech-item group flex flex-col items-center gap-2 rounded-xl border p-4 transition-all hover:border-primary/50 hover:bg-primary/5"
              data-category={tech.category}
            >
              <div class="size-8 shrink-0">
                <tech.icon
                  class={`h-full w-full object-contain ${inverteds.some((inverted) => tech.name.toLowerCase().includes(inverted)) ? "dark:invert-100" : ""}`}
                />
              </div>
              <span class="text-center text-xs text-foreground/60 group-hover:text-foreground">
                {tech.name}
              </span>
            </div>
          ))
        }
      </div>

      <script>
        const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn")
        const items = document.querySelectorAll<HTMLElement>(".tech-item")

        buttons.forEach((btn) => {
          btn.addEventListener("click", () => {
            const selected = btn.dataset.category!

            // Update active button styles
            buttons.forEach((b) => {
              const isActive = b.dataset.category === selected
              b.classList.toggle("border-primary", isActive)
              b.classList.toggle("bg-primary", isActive)
              b.classList.toggle("text-black", isActive)
              b.classList.toggle("border-border", !isActive)
              b.classList.toggle("text-foreground/60", !isActive)
            })

            // Show / hide items
            items.forEach((item) => {
              const match = selected === "all" || item.dataset.category === selected
              item.style.display = match ? "" : "none"
            })
          })
        })
      </script>
    </div>

    <InterestedWithMe />
  </div>
</Layout>
