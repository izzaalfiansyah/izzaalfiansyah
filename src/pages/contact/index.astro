---
import Layout from "@/layouts/Layout.astro"
import { contactLinks } from "@/data/contact"
import { ChevronRight } from "@lucide/astro"
---

<Layout
  title="Contact"
  meta={{
    description:
      "Then places where you can find me. Find me on GitHub, LinkedIn, WhatsApp, and more.",
  }}
>
  <div class="mx-auto max-w-4xl px-6 py-16">
    <div class="mb-12">
      <p
        class="text-sm font-medium text-primary uppercase tracking-widest mb-2"
      >
        Get in touch
      </p>
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Contact</h1>
      <p class="mt-2 text-foreground/60">The places where you can find me</p>
    </div>

    <div class="grid gap-3 grid-cols-1 sm:grid-cols-2 md:grid-cols-3">
      {
        contactLinks.map((link) => (
          <a
            href={link.url}
            target={link.url.startsWith("mailto") ? undefined : "_blank"}
            rel={
              link.url.startsWith("mailto") ? undefined : "noopener noreferrer"
            }
            class="group flex items-center gap-4 rounded-xl border p-5 transition-all hover:border-primary/50 hover:shadow-lg hover:shadow-primary/5"
          >
            <div class="size-10 shrink-0 overflow-hidden rounded-full bg-foreground/5 p-2">
              <link.icon
                class={`h-full w-full object-contain ${link.url.includes("github") ? "dark:invert-100" : ""}`}
              />
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold">{link.name}</p>
              <p class="text-xs text-foreground/50 group-hover:text-primary transition-colors truncate">
                {link.url.replace(/^https?:\/\//, "").replace(/^mailto:/, "")}
              </p>
            </div>
            <ChevronRight
              size={14}
              class="shrink-0 text-foreground/30 transition-colors group-hover:text-primary"
            />
          </a>
        ))
      }
    </div>

    <!-- Extra CTA -->
    <div
      class="mt-16 rounded-2xl border border-primary/20 bg-primary/5 p-8 text-center"
    >
      <h3 class="text-xl font-bold">Let's work together</h3>
      <p class="mt-2 text-foreground/60">
        I am open to new opportunities. Feel free to reach out!
      </p>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <a
          href="https://api.whatsapp.com/send?phone=6281231921351"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-black transition-opacity hover:opacity-90"
        >
          Send Message
        </a>
        <a
          href="https://www.linkedin.com/in/muhammad-izza-alfiansyah-76a473220"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg border px-6 py-2.5 text-sm font-semibold transition-colors hover:border-primary/50 hover:text-primary"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</Layout>
