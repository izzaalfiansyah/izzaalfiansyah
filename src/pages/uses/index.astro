---
import Layout from "@/layouts/Layout.astro"
import { usesCategories } from "@/data/uses"
---

<Layout
  title="Uses"
  meta={{
    description:
      "A curated list of the tools and setup that use to build, code, and maintain a productive workflow.",
  }}
>
  <div class="mx-auto max-w-4xl px-6 py-16">
    <div class="mb-12">
      <p
        class="text-sm font-medium text-primary uppercase tracking-widest mb-2"
      >
        Setup
      </p>
      <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Uses</h1>
      <p class="mt-2 text-foreground/60">
        A curated list of the tools and setup I use to build, code, and maintain
        a productive workflow.
      </p>
    </div>

    <!-- Desktop illustration -->
    <div class="mb-12 overflow-hidden rounded-2xl border bg-foreground/5">
      <img
        src="https://izzaalfiansyah.my.id/_nuxt/desktop.tt8b0Lr9.png"
        alt="My desktop setup"
        class="w-full object-cover"
        loading="lazy"
      />
    </div>

    <!-- Categories -->
    <div class="space-y-10">
      {
        usesCategories.map((category) => (
          <div>
            <h2 class="mb-3 text-base font-semibold text-foreground">
              {category.title}
            </h2>
            <ul class="space-y-2">
              {category.items.map((item) => (
                <li class="flex items-baseline gap-2 text-sm">
                  <span class="shrink-0 text-foreground/30">–</span>
                  <span>
                    <a
                      href={item.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-medium text-primary transition-colors"
                    >
                      {item.name}
                    </a>
                    <span class="text-foreground/50">
                      {" "}
                      — {item.description}
                    </span>
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</Layout>
